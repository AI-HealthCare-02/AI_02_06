# 로컬 개발 환경 설정 예시
# 이 파일을 .env.local 로 복사하여 값을 채워 사용하세요.
# cp .env.example .env.local

# FastAPI 서버 주소
# - 로컬 (next dev + uvicorn 직접 실행): http://localhost:8000
# - Docker (Nginx 프록시 사용): 빈 문자열로 둠
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 환경 구분 (local | dev | prod)
# local: Mock 카카오 서버 + 개발자 로그인 버튼 표시
# dev/prod: 실제 카카오 서버, 개발자 로그인 버튼 숨김
NEXT_PUBLIC_ENV=local
