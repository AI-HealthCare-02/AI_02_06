# ============================================================
# Next.js 환경 설정
# ============================================================
# 이 파일을 복사해서 .env.local로 저장하세요.
# cp .env.example .env.local
#
# [핵심] NEXT_PUBLIC_ENV만 변경하면 URL 자동 설정!
# ============================================================

# ============================================================
# [1] 환경 선택 - 이것만 바꾸면 URL 자동 설정!
# ============================================================
# local: 로컬 개발 (API: localhost:8000)
# dev: 개발/테스트 서버 (API: 52.78.62.12, Vercel Preview)
# prod: 프로덕션 (API: 52.78.62.12, Vercel Production)
NEXT_PUBLIC_ENV=local

# ============================================================
# [2] Kakao OAuth
# ============================================================
NEXT_PUBLIC_KAKAO_CLIENT_ID=

# ============================================================
# [자동 설정됨] - 수동 입력 불필요!
# ============================================================
# src/config/env.js에서 NEXT_PUBLIC_ENV에 따라 자동 설정됩니다.
# 특별히 다른 값을 원할 때만 주석 해제 후 입력하세요.
#
# [local]
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
#
# [dev]
# NEXT_PUBLIC_API_BASE_URL=http://52.78.62.12
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=https://downforce-dev.vercel.app/auth/kakao/callback
#
# [prod]
# NEXT_PUBLIC_API_BASE_URL=http://52.78.62.12
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=https://downforce.vercel.app/auth/kakao/callback
