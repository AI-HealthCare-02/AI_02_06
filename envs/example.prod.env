# ============================================================
# Production 환경 (EC2 + Vercel)
# ============================================================
# 사용법: EC2에서 cp envs/example.prod.env .env 후 실제 값 입력
# Vercel: Dashboard에서 NEXT_PUBLIC_ENV=prod, API_BASE_URL 설정
# ============================================================

# 환경
ENV=prod
NEXT_PUBLIC_ENV=prod

# 보안 (필수! 실제 값으로 변경)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_64_CHAR_RANDOM_STRING
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# 카카오 (필수! 실제 값으로 변경)
KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET

# DB & Redis (Docker Compose)
DB_HOST=postgres
DB_PORT=5432
DB_USER=downforce_admin
DB_NAME=downforce_db
REDIS_URL=redis://redis:6379/0

# AI Worker (선택)
# CLOVA_OCR_INVOKE_URL=
# CLOVA_OCR_SECRET_KEY=
# OPENAI_API_KEY=

# 파일 로그 디렉토리 (RotatingFileHandler) — 컨테이너 내부 경로.
# 호스트 ~/AI_02_06/logs/<service> 로 volume 마운트. 매 deploy 시작 시
# logs.prev 로 한 세대 백업 후 logs/ 새로 생성 — 라이프사이클 관리는
# .github/workflows/deploy.yml 에서 처리.
LOG_DIR=/app/logs

# ============================================================
# Vercel 환경변수 (Dashboard에서 설정)
# ============================================================
# NEXT_PUBLIC_ENV=prod
# API_BASE_URL=http://52.78.62.12
