# ============================================================
# 로컬 환경 (local / dev)
# ============================================================
# 사용법: cp envs/example.local.env .env
#
# local: dev 로그인 버튼 O (빠른 개발)
# dev:   dev 로그인 버튼 X (카카오 테스트)
# ============================================================

# 환경 (local 또는 dev)
ENV=local
NEXT_PUBLIC_ENV=local

# 보안 (로컬용)
SECRET_KEY=local-dev-secret-key-change-in-production
DB_PASSWORD=pw1234

# 카카오 (local: mock 사용, dev: 실제 키 입력)
KAKAO_CLIENT_ID=mock_kakao_client_id
KAKAO_CLIENT_SECRET=mock_kakao_client_secret

# DB & Redis (Docker Compose)
DB_HOST=postgres
DB_PORT=5432
DB_USER=downforce_admin
DB_NAME=downforce_db
REDIS_URL=redis://redis:6379/0
