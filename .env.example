# ============================================================
# Downforce 환경 변수
# ============================================================
# 사용법: envs/ 폴더에서 환경에 맞는 파일을 복사하세요.
#   로컬: cp envs/local.example .env
#   EC2:  cp envs/prod.example .env
# ============================================================

# ============================================================
# [1] 환경 선택 - 이것만 바꾸면 URL 자동 설정!
# ============================================================
# local: 로컬 Docker (dev 로그인 버튼 O)
# dev:   로컬 Docker (dev 로그인 버튼 X, 카카오 테스트용)
# prod:  EC2 + Vercel 배포
ENV=local

# ============================================================
# [2] 보안 (필수)
# ============================================================
SECRET_KEY=your-secret-key-here
DB_PASSWORD=your-db-password

# ============================================================
# [3] 카카오 OAuth (필수)
# ============================================================
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ============================================================
# [4] DB & Redis
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=downforce_admin
DB_NAME=downforce_db
REDIS_URL=redis://redis:6379/0

# ============================================================
# [5] AI Worker (선택)
# ============================================================
# CLOVA_OCR_INVOKE_URL=
# CLOVA_OCR_SECRET_KEY=
# OPENAI_API_KEY=

# ============================================================
# [6] 프론트엔드 (NEXT_PUBLIC_*)
# ============================================================
# ENV와 동일하게 설정하세요.
NEXT_PUBLIC_ENV=local

# ============================================================
# [자동 설정] ENV에 따라 config.py에서 자동 적용됨
# ============================================================
# local/dev:
#   FRONTEND_URL=http://localhost:3000
#   KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
#
# prod:
#   FRONTEND_URL=https://ai-02-06.vercel.app
#   KAKAO_REDIRECT_URI=https://ai-02-06.vercel.app/auth/kakao/callback
