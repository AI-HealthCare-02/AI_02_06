# ============================================================
# Environment Configuration
# ============================================================
# ENV: 실행 환경 (local | dev | prod)
#   - local: Mock OAuth (카카오 앱 없이 테스트), 개발자 버튼 표시
#   - dev: 실제 카카오 OAuth, 개발자 버튼 표시
#   - prod: 실제 카카오 OAuth, 개발자 버튼 숨김
ENV=dev
TIMEZONE=Asia/Seoul

# ============================================================
# Security - JWT
# ============================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160
JWT_LEEWAY=5

# ============================================================
# Docker Build
# ============================================================
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health
APP_VERSION=v1.0.0
AI_WORKER_VERSION=v1.0.0

# ============================================================
# URL Configuration (환경별 설정)
# ============================================================
# COOKIE_DOMAIN: JWT 쿠키 도메인
#   - local/dev: localhost
#   - prod: 실제 도메인 (예: downforce.kr)
COOKIE_DOMAIN=localhost

# API_BASE_URL: FastAPI 서버 URL (서버 간 통신용)
#   - local: http://localhost:8000 (FastAPI 직접)
#   - dev: http://fastapi:8000 (Docker 네트워크)
#   - prod: https://api.downforce.kr
API_BASE_URL=http://localhost:8000

# FRONTEND_URL: 브라우저 리다이렉트용 URL
#   - local: http://localhost:3000 (Next.js dev server)
#   - dev: http://localhost (Nginx)
#   - prod: https://downforce.kr
FRONTEND_URL=http://localhost:3000

# ============================================================
# [REQUIRED] 보안 필수 설정 - 반드시 값 입력 필요
# ============================================================
# SECRET_KEY: JWT 서명 비밀키 (최소 32자)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# DB_PASSWORD: 데이터베이스 비밀번호
DB_PASSWORD=

# KAKAO_CLIENT_ID: Kakao Developers REST API 키
# KAKAO_CLIENT_SECRET: Kakao Developers Secret 키
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_HOST=52.78.62.12
DB_PORT=5432
DB_USER=downforce_admin
DB_NAME=downforce_db
DB_CONNECT_TIMEOUT=5
DB_CONNECTION_POOL_MAXSIZE=10

# ============================================================
# Kakao OAuth
# ============================================================
# KAKAO_REDIRECT_URI: 카카오 인증 후 콜백 URL
#   - local: http://localhost:3000/auth/kakao/callback
#   - dev: http://localhost/auth/kakao/callback
#   - prod: https://downforce.kr/auth/kakao/callback
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# ============================================================
# Frontend (Next.js) - NEXT_PUBLIC_ 접두사는 클라이언트에 노출됨
# ============================================================
# NEXT_PUBLIC_ENV: 프론트엔드 환경 (local/dev/prod)
#   - local/dev: 개발자 로그인 버튼 표시
#   - prod: 개발자 로그인 버튼 숨김
NEXT_PUBLIC_ENV=dev

# NEXT_PUBLIC_API_BASE_URL: 브라우저에서 API 호출 시 URL
#   - local: http://localhost:8000 (FastAPI 직접)
#   - dev/prod: (빈 문자열) -> Nginx 프록시 사용
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

NEXT_PUBLIC_KAKAO_CLIENT_ID=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback