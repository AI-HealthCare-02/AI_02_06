# ============================================================
# Downforce 환경 설정
# ============================================================
# 이 파일을 복사해서 .env로 저장하고 값을 입력하세요.
# cp .env.example .env
#
# [핵심] ENV 값만 변경하면 URL들이 자동으로 설정됩니다!
# ============================================================

# ============================================================
# [1] 환경 선택 - 이것만 바꾸면 URL 자동 설정!
# ============================================================
# local: 로컬 개발 (모두 localhost)
# dev: 개발/테스트 서버 (EC2 + Vercel Preview)
# prod: 프로덕션 (EC2 + Vercel Production)
ENV=local

# ============================================================
# [2] 필수 입력 - 민감 정보
# ============================================================
# SECRET_KEY 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 데이터베이스 비밀번호
DB_PASSWORD=

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ============================================================
# [3] 데이터베이스
# ============================================================
# local: localhost (로컬 Docker 또는 직접 설치)
# prod: 52.78.62.12 (EC2)
DB_HOST=localhost
DB_PORT=5432
DB_USER=downforce_admin
DB_NAME=downforce_db

# ============================================================
# [4] Redis
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# [5] Docker (빌드용)
# ============================================================
DOCKER_USER=local
DOCKER_REPOSITORY=downforce
APP_VERSION=v1.0.0
AI_WORKER_VERSION=v1.0.0

# ============================================================
# [6] AI Worker (선택 - 없으면 OCR 기능 비활성화)
# ============================================================
# CLOVA_OCR_INVOKE_URL=
# CLOVA_OCR_SECRET_KEY=
# OPENAI_API_KEY=

# ============================================================
# [자동 설정됨] ENV에 따라 자동 적용 - 수동 입력 불필요!
# ============================================================
# 아래 값들은 config.py에서 ENV에 따라 자동 설정됩니다.
# 특별히 다른 값을 원할 때만 주석 해제 후 입력하세요.
#
# [ENV=local 일 때 자동 적용]
# COOKIE_DOMAIN=localhost
# API_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000
# KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
#
# [ENV=dev 일 때 자동 적용]
# COOKIE_DOMAIN=52.78.62.12
# API_BASE_URL=http://52.78.62.12
# FRONTEND_URL=https://downforce-dev.vercel.app
# KAKAO_REDIRECT_URI=https://downforce-dev.vercel.app/auth/kakao/callback
#
# [ENV=prod 일 때 자동 적용]
# COOKIE_DOMAIN=52.78.62.12
# API_BASE_URL=http://52.78.62.12
# FRONTEND_URL=https://downforce.vercel.app
# KAKAO_REDIRECT_URI=https://downforce.vercel.app/auth/kakao/callback

# ============================================================
# 프론트엔드 환경 변수 (Next.js)
# ============================================================
# NEXT_PUBLIC_ENV: 프론트엔드도 ENV와 동일하게 설정
# - local: 개발자 로그인 버튼 표시
# - prod: 개발자 로그인 버튼 숨김
NEXT_PUBLIC_ENV=local

# 아래는 src/config/env.js에서 NEXT_PUBLIC_ENV에 따라 자동 설정됨
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=

# Kakao Client ID (프론트엔드용)
NEXT_PUBLIC_KAKAO_CLIENT_ID=
